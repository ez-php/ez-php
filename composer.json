{
  "name": "ez-php/ez-php",
  "version": "1.9.0",
  "description": "ez-php application template",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": "^8.5",
    "ez-php/framework": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "require-dev": {
    "ez-php/testing-application": "^1.0",
    "phpunit/phpunit": "^13.0",
    "phpstan/phpstan": "^2.1",
    "friendsofphp/php-cs-fixer": "^3.94",
    "phpstan/phpstan-strict-rules": "^2.0",
    "phpstan/phpstan-deprecation-rules": "^2.0"
  },
  "scripts": {
    "post-create-project-cmd": [
      "php bin/setup"
    ],
    "cs": "php-cs-fixer fix",
    "analyse": "phpstan analyse",
    "test": "phpunit",
    "full": "composer analyse && composer cs && composer test"
  }
}
