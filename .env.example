# APP
APP_NAME=ez-php
APP_PORT=8001
APP_ENV=local
APP_DEBUG=true
APP_LOCALE=en
APP_FALLBACK_LOCALE=en

# CACHE
REDIS_PORT=6381
CACHE_DRIVER=file
CACHE_PATH=/tmp/ez-cache
CACHE_REDIS_HOST=redis
CACHE_REDIS_PORT=6379
CACHE_REDIS_DB=0

# MAIL
MAIL_DRIVER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_WEB_PORT=8025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=none
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME=ez-php

# DATABASE
DB_HOST=db
DB_HOST_PORT=3308
DB_DATABASE=ez-php
DB_USERNAME=ez-php
DB_PASSWORD=ez-php
DB_TESTING_DATABASE=ez-php_testing
