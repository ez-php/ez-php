# APP
APP_NAME=ez-php
APP_ENV=local
APP_DEBUG=true
APP_LOCALE=en
APP_FALLBACK_LOCALE=en

# CACHE
CACHE_DRIVER=file
CACHE_PATH=/tmp/ez-cache
CACHE_REDIS_HOST=redis
CACHE_REDIS_PORT=6379
CACHE_REDIS_DB=0

# DATABASE
DB_HOST=db
DB_PORT=3308
DB_DATABASE=ez-php
DB_USERNAME=ez-php
DB_PASSWORD=ez-php
DB_TESTING_DATABASE=ez-php_testing
