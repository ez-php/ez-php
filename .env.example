# APP
APP_NAME=ez-php
APP_PORT=8001
APP_ENV=local
APP_DEBUG=true
APP_LOCALE=en
APP_FALLBACK_LOCALE=en

# CACHE
REDIS_PORT=6381
CACHE_DRIVER=file
CACHE_PATH=/tmp/ez-cache
CACHE_REDIS_HOST=redis
CACHE_REDIS_PORT=6379
CACHE_REDIS_DB=0

# DATABASE
DB_HOST=db
DB_HOST_PORT=3308
DB_DATABASE=ez-php
DB_USERNAME=ez-php
DB_PASSWORD=ez-php
DB_TESTING_DATABASE=ez-php_testing

# MAIL
MAIL_DRIVER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_WEB_PORT=8025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=none
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME=ez-php
MAIL_LOG_PATH=

# QUEUE
QUEUE_DRIVER=database
QUEUE_REDIS_HOST=redis
QUEUE_REDIS_PORT=6379
QUEUE_REDIS_DB=0

# RATE LIMITER
RATE_LIMITER_DRIVER=array
RATE_LIMITER_REDIS_HOST=redis
RATE_LIMITER_REDIS_PORT=6379
RATE_LIMITER_REDIS_DB=0

# VIEW
VIEW_PATH=resources/views

# BROADCAST
BROADCAST_DRIVER=null
BROADCAST_LOG_PATH=

# SEARCH
SEARCH_DRIVER=null
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=
# ELASTICSEARCH_HOST=http://elasticsearch:9200
# ELASTICSEARCH_USER=
# ELASTICSEARCH_PASSWORD=
